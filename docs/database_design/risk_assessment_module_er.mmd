  B1(["分析id"]) --- ANALYSIS;
  B2(["资产id"]) --- ANALYSIS;
  B3(["资产类型"]) --- ANALYSIS;
  B4(["模型置信度"]) --- ANALYSIS;
  B5(["分析时间"]) --- ANALYSIS;

  C1(["标签id"]) --- TAG;
  C2(["资产id"]) --- TAG;
  C3(["标签名称"]) --- TAG;
  C4(["标签来源"]) --- TAG;
  C5(["置信度"]) --- TAG;
  C6(["命中规则"]) --- TAG;
  C7(["创建时间"]) --- TAG;

  D1(["风险id"]) --- RISK;
  D2(["资产id"]) --- RISK;
  D3(["风险分值"]) --- RISK;
  D4(["风险等级"]) --- RISK;
  D5(["评分详情"]) --- RISK;
  D6(["修复建议"]) --- RISK;
  D7(["评估时间"]) --- RISK;
